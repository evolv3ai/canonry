{
  "name": "@ainyc/canonry",
  "version": "1.0.0",
  "type": "module",
  "license": "AGPL-3.0-only",
  "bin": {
    "canonry": "./bin/canonry.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./src/index.ts",
  "files": [
    "bin/",
    "dist/",
    "assets/",
    "src/"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup && tsx build-web.ts",
    "build:web": "tsx build-web.ts",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test test/*.test.ts",
    "lint": "eslint src/ test/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/static": "^8.1.0",
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.4.0",
    "node-cron": "^4.2.1",
    "openai": "^4.85.0",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.7.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@ainyc/canonry-api-routes": "workspace:*",
    "@ainyc/canonry-contracts": "workspace:*",
    "@ainyc/canonry-db": "workspace:*",
    "@ainyc/canonry-provider-claude": "workspace:*",
    "@ainyc/canonry-provider-gemini": "workspace:*",
    "@ainyc/canonry-provider-local": "workspace:*",
    "@ainyc/canonry-provider-openai": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node-cron": "^3.0.11",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0"
  }
}
