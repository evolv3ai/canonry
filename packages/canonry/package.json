{
  "name": "@ainyc/canonry",
  "version": "1.44.0",
  "type": "module",
  "description": "The ultimate open-source AEO monitoring tool - track how answer engines cite your domain",
  "license": "FSL-1.1-ALv2",
  "homepage": "https://ainyc.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/AINYC/canonry.git",
    "directory": "packages/canonry"
  },
  "bugs": {
    "url": "https://github.com/AINYC/canonry/issues"
  },
  "bin": {
    "canonry": "./bin/canonry.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "bin/",
    "dist/",
    "assets/",
    "package.json",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup && tsx build-web.ts",
    "build:web": "tsx build-web.ts",
    "prepublishOnly": "cp ../../README.md ./README.md && pnpm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src/ test/"
  },
  "dependencies": {
    "@ainyc/aeo-audit": "1.3.2",
    "@anthropic-ai/sdk": "^0.78.0",
    "@fastify/static": "^8.1.0",
    "@google/genai": "^1.46.0",
    "better-sqlite3": "^12.6.2",
    "chrome-remote-interface": "^0.33.2",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.4.0",
    "node-cron": "^4.2.1",
    "openai": "^6.0.0",
    "pdf-lib": "^1.17.1",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.7.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@ainyc/canonry-api-routes": "workspace:*",
    "@ainyc/canonry-config": "workspace:*",
    "@ainyc/canonry-contracts": "workspace:*",
    "@ainyc/canonry-db": "workspace:*",
    "@ainyc/canonry-intelligence": "workspace:*",
    "@ainyc/canonry-integration-bing": "workspace:*",
    "@ainyc/canonry-integration-google": "workspace:*",
    "@ainyc/canonry-integration-wordpress": "workspace:*",
    "@ainyc/canonry-provider-cdp": "workspace:*",
    "@ainyc/canonry-provider-claude": "workspace:*",
    "@ainyc/canonry-provider-gemini": "workspace:*",
    "@ainyc/canonry-provider-local": "workspace:*",
    "@ainyc/canonry-provider-openai": "workspace:*",
    "@ainyc/canonry-provider-perplexity": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node-cron": "^3.0.11",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0"
  }
}
